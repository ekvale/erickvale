# Copy to `.env` and fill in real values. Do not commit `.env`.

# Database (existing)
DB_NAME=erickvale
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Dream Blue: monthly digest recipients (comma-separated, no spaces required) ---
# Example only — use your real internal addresses in `.env`.
DREAM_BLUE_REPORT_RECIPIENTS=you@example.com,colleague@example.com

# Option A: Resend (HTTPS API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-verified-domain.example
# Optional override:
# RESEND_API_URL=https://api.resend.com/emails

# Option B: SMTP (used when Resend key/from are empty). Example placeholders only.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@your-domain.example

# Optional: console backend for local debugging
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- GrantScout agent (python manage.py grantscout_run_agent) ---
# Provider: openai (default), anthropic (Claude), or perplexity.
# GRANTSCOUT_LLM_PROVIDER=openai
OPENAI_API_KEY=
# GRANTSCOUT_OPENAI_MODEL=gpt-4o-mini
#
# Anthropic (Claude) — set GRANTSCOUT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# GRANTSCOUT_ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheaper / faster: claude-haiku-4-5 (see Anthropic models docs)
#
# PERPLEXITY_API_KEY=
# GRANTSCOUT_LLM_PROVIDER=perplexity
# GRANTSCOUT_PERPLEXITY_MODEL=sonar
#
# GrantScout URL checks (GET each source_url; drops 404/5xx). Disable with False if needed.
# GRANTSCOUT_VALIDATE_SOURCE_URLS=True
# GRANTSCOUT_URL_CHECK_TIMEOUT=15
# GRANTSCOUT_URL_CHECK_DELAY_SEC=0.25
