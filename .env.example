# Copy to `.env` and fill in real values. Do not commit `.env`.

# Database (existing)
DB_NAME=erickvale
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Brain dump (personal inbox + monthly calendar email) ---
# Exactly one of: matching username, or numeric user id (Django User.pk).
BRAINDUMP_OWNER_USERNAME=eric
# BRAINDUMP_OWNER_USER_ID=3
# Categorization: Anthropic and/or Perplexity (set at least one). Primary provider tries first, then the other.
# BRAINDUMP_LLM_PROVIDER=anthropic   # or perplexity
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# BRAINDUMP_ANTHROPIC_MODEL=   # optional; else GRANTSCOUT_ANTHROPIC_MODEL or Haiku default
# BRAINDUMP_PERPLEXITY_MODEL=  # optional; else GRANTSCOUT_PERPLEXITY_MODEL or sonar
# Monthly calendar email recipients (comma-separated); default is owner’s user.email
# BRAINDUMP_CALENDAR_EMAIL_RECIPIENTS=you@example.com
# Optional link base for morning digest emails (else uses DREAM_BLUE_DIGEST_BASE_URL)
# BRAINDUMP_DIGEST_BASE_URL=https://your.domain.org
# Cron: monthly calendar — python manage.py send_braindump_monthly_calendar
# Cron: morning digest 5:30 server time — 30 5 * * * cd /path/to/erickvale && venv/bin/python manage.py send_braindump_morning_digest
# Optional: recurring rules only (digest also runs rules before send) — 25 5 * * * ... process_braindump_recurring

# --- Dream Blue: biweekly combined report (calendar, KPIs, GrantScout) ---
# Recipients (comma-separated).
DREAM_BLUE_REPORT_RECIPIENTS=you@example.com,colleague@example.com
# Days ahead to include for Business calendar events in the email (default 120).
# DREAM_BLUE_CALENDAR_LOOKAHEAD_DAYS=120
# Digest “Money moves” block: max rows (vacancy + rollover priority list).
# DREAM_BLUE_MONEY_MOVES_LIMIT=5
#
# Digest “lease economics”: economic vacancy %, cap-rate implied value band (default 8–10%), optional extra $/sf benchmark.
# DREAM_BLUE_LEASE_ECONOMICS_VACANCY_PCT=8
# DREAM_BLUE_CAP_RATE_BENCHMARK_LOW=8
# DREAM_BLUE_CAP_RATE_BENCHMARK_HIGH=10
# Suggested asking rents in digest ($/sf/yr gross on above-grade; lower tier on storage sf).
# DREAM_BLUE_SUGGEST_RENT_PSF_YEAR_ABOVE=9.5
# DREAM_BLUE_SUGGEST_RENT_PSF_YEAR_STORAGE=2
# DREAM_BLUE_RENT_BENCHMARK_PSF_YEAR=
# DREAM_BLUE_RENT_BENCHMARK_NOTE=Gross $/sf/yr, Bemidji retail, source + date

# Option A: Resend (HTTPS API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-verified-domain.example
# Optional override:
# RESEND_API_URL=https://api.resend.com/emails

# Option B: SMTP (used when Resend key/from are empty). Example placeholders only.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@your-domain.example

# Optional: console backend for local debugging
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- GrantScout agent (python manage.py grantscout_run_agent) ---
# Provider: openai (default), anthropic (Claude), or perplexity.
# GRANTSCOUT_LLM_PROVIDER=openai
OPENAI_API_KEY=
# GRANTSCOUT_OPENAI_MODEL=gpt-4o-mini
#
# Anthropic (Claude) — set GRANTSCOUT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# GRANTSCOUT_ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheaper / faster: claude-haiku-4-5 (see Anthropic models docs)
#
# PERPLEXITY_API_KEY=
# GRANTSCOUT_LLM_PROVIDER=perplexity
# GRANTSCOUT_PERPLEXITY_MODEL=sonar
#
# GrantScout digest email: optional comma-separated topic_tags allowlist (lowercase). When set, only
# opportunities whose topic_tags overlap appear in the digest (shortens noisy runs).
# GRANTSCOUT_DIGEST_TOPIC_TAGS=bemidji,retail
#
# GrantScout URL checks (GET each source_url; drops 404/5xx). Disable with False if needed.
# GRANTSCOUT_VALIDATE_SOURCE_URLS=True
# GRANTSCOUT_URL_CHECK_TIMEOUT=15
# GRANTSCOUT_URL_CHECK_DELAY_SEC=0.25
# Bytes of HTML to scan for “page moved” placeholders (HTTP 200 soft dead links)
# GRANTSCOUT_URL_CONTENT_PEEK_BYTES=98304
